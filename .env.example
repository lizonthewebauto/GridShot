# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kie.ai (single AI provider for everything)
# Single-slide writing uses gemini-2.5-flash (chat completions, src/lib/ai/client.ts).
# Drafts pipeline (vision + structured output) uses gpt-5.5 by default — override via KIEAI_DRAFT_MODEL.
KIEAI_API_KEY=
# KIEAI_DRAFT_MODEL=gpt-5.5

# Bundle Social
BUNDLE_SOCIAL_API_KEY=

# Google Drive import (Picker API)
# Configure at https://console.cloud.google.com/ — enable Drive API + Picker API
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=
NEXT_PUBLIC_GOOGLE_DRIVE_APP_ID=

# Stripe (Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
